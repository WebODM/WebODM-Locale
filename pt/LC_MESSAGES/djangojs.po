#: app/static/app/js/translations/odm_autogenerated.js:58
#, python-format
msgid ""
"Do not use GPU acceleration, even if it's available. Default: %(default)s"
msgstr ""
"Não utilize a aceleração por GPU, mesmo que esteja disponível. Por defeito: "
"%(default)s"

#: app/static/app/js/translations/odm_autogenerated.js:59
#, python-format
msgid ""
"Turn off camera parameter optimization during bundle adjustment. This can be "
